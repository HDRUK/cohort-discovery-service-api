APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_OPERATION_MODE="standalone"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1


REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PASSPORT_TOKEN_EXPIRES_IN_DAYS=30
PASSPORT_REFRESH_TOKEN_EXPIRES_IN_DAYS=60
PASSPORT_ACCESS_TOKEN_EXPIRES_IN_MONTHS=6

API_RATE_LIMIT=1000
DEFAULT_PER_PAGE=25
MAX_ATTEMPTS=3
TASK_TIMEOUT_SECONDS=300
LEASE_SECONDS=60

INTEGRATED_JWT_SECRET="secret_key_here"
INTEGRATED_API_URI="http://localhost:8000/api/v1/"
INTEGRATED_AUTHORISATION_URI="http://localhost:8000/oauth2/token"
INTEGRATED_CLIENT_ID="client_id_here"
INTEGRATED_CLIENT_SECRET="client_secret_here"
OAUTH_PLACEHOLDER_PASSWORD="placeholder_password_here"
OAUTH_INTERNAL_REDIRECT="http://localhost:8200/auth/callback"

CLAIMS_ACCESS_DEFAULT_SYSTEM="default_system_name"

COLLECTION_HOSTS_KEY_SALT_1="salt_value_1_here"
COLLECTION_HOSTS_KEY_SALT_2="salt_value_2_here"

JWT_SECRET=1234abcde

INTEGRATED_TEST_USER_EMAIL="test@test.com"
INTEGRATED_TEST_USER_PASSWORD="password1234"

# Can be either "log" or "record"
# log - We create or update an entry in collection_activity_log table
# record - We update the timestamp against the collection itself
COLLECTION_ACTIVITY_LOG_TYPE="log"
COHORT_DISCOVER_NLP_SERVICE_BASE_URI="http://localhost:5001"

# Configures the TTL for standalone JWTs in minutes, overriding
# the default TTL inherited from Passport.
STANDALONE_JWT_TTL_MINUTES=120
